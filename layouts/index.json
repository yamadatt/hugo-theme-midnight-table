{{- $pages := where .Site.RegularPages "Section" "posts" -}}
[
{{- range $index, $page := $pages -}}
  {{- if $index -}},{{- end }}
  {
    "title": {{ $page.Title | jsonify }},
    "url": {{ $page.RelPermalink | jsonify }},
    "date": {{ $page.Date.Format "2006-01-02" | jsonify }},
    "summary": {{ with $page.Params.summary }}{{ . | plainify | jsonify }}{{ else }}{{ $page.Summary | plainify | jsonify }}{{ end }},
    "categories": {{ if and (ne $.Site.Params.showCategories false) (isset $.Site.Taxonomies "categories") }}{{ with $page.Params.categories }}{{ . | jsonify }}{{ else }}[]{{ end }}{{ else }}[]{{ end }},
    "tags": {{ with $page.Params.tags }}{{ . | jsonify }}{{ else }}[]{{ end }},
    "content": {{ $page.Plain | plainify | truncate 1200 | jsonify }}
  }
{{- end }}
]
